      "tier": "open-attackable",
      "provider": "siliconflow",
      "model": "Qwen/Qwen3-8B",
      "enable_thinking": false,
      "max_tokens": 512,
      "temperature": 0.7
    },
    {
      "name": "qwen3-14b", "tier": "open-attackable",
